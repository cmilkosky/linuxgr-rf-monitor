HACKRF_SWEEP_ARGS=-f 400:6000 -w 1000000
SWEEP_INTERVAL=60
INFLUX_MEASUREMENT=rf_sweep
RF_SOURCE=hackrf_linuxgr

# InfluxDB 2.x
INFLUX_URL=http://127.0.0.1:8086
INFLUX_ORG=home
INFLUX_BUCKET=rf_monitoring
INFLUX_TOKEN=replace_me

# Or InfluxDB 1.x
# INFLUX_URL=http://127.0.0.1:8086
# INFLUX_DB=rf_monitoring
# INFLUX_USER=
# INFLUX_PASSWORD=
